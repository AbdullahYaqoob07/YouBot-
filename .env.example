# LangGraph AI Agent Environment Configuration

# Application
APP_NAME=Sweden Relocators AI Agent
DEBUG=False
API_VERSION=v1

# LLM Configuration (from n8n workflow)
# n8n used: llama3-70b-8192 for both Supervisor and Main LLM
# Supervisor: temp=0.1, max_tokens=300 (routing)
# Main LLM: temp=0.3, max_tokens=1000 (responses)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192
GROQ_TEMPERATURE=0.3
GROQ_MAX_TOKENS=1000

# # Optional: OpenAI for embeddings
# OPENAI_API_KEY=your_openai_key_here

# Database (MySQL)
# Update 'password' with your actual MySQL root password
DATABASE_URL=mysql+asyncmy://root:password@localhost:3306/sweden_relocators_ai
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Checkpointing (SQLite for LangGraph state persistence)
CHECKPOINT_DB=sqlite:///checkpoints.db

# Vector Store (from n8n workflow)
# n8n used: VECTOR_DB_URL=http://localhost:8000/api/v1/query
# top_k=3 for retrieval
# VECTOR_STORE_TYPE=chroma
# VECTOR_STORE_PATH=./data/chroma_db
# VECTOR_DB_URL=http://localhost:8000
# VECTOR_TOP_K=3

# Pinecone (if using)
# PINECONE_API_KEY=your_pinecone_key
# PINECONE_ENVIRONMENT=us-east-1
# PINECONE_INDEX=sweden-relocators

# Email Configuration (for admin notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@swedenrelocators.com

# Admin Emails
ADMIN_EMAILS=["admin@swedenrelocators.se"]

# Security
API_KEYS=[]  # Add your API keys here as comma-separated list
RATE_LIMIT_PER_MINUTE=100

# Workflow Configuration
MAX_CONVERSATION_HISTORY=10
SPAM_THRESHOLD=1.0
INTENT_CONFIDENCE_THRESHOLD=0.8

# Knowledge Base (from n8n workflow: top_k=3)
KNOWLEDGE_BASE_TOP_K=5
KNOWLEDGE_BASE_SIMILARITY_THRESHOLD=0.7

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/agent.log

# Performance
WORKERS=4
REQUEST_TIMEOUT=30

# URLs
WEBSITE_URL=https://swedenrelocators.se
