# LangGraph AI Agent Environment Configuration

# Application
APP_NAME=Sweden Relocators AI Agent
DEBUG=False
API_VERSION=v1

# LLM Configuration (from n8n workflow)
# n8n used: llama3-70b-8192 for both Supervisor and Main LLM
# Supervisor: temp=0.1, max_tokens=300 (routing)
# Main LLM: temp=0.3, max_tokens=1000 (responses)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192
GROQ_TEMPERATURE=0.3
GROQ_MAX_TOKENS=1000

# # Optional: OpenAI for embeddings
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_MODEL=gpt-4o-mini

# Optional: Anthropic
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Optional: Gemini
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-1.5-pro

# SaaS default routing (fallback when workspace config is missing)
DEFAULT_LLM_PROVIDER=groq
# DEFAULT_LLM_MODEL=

# Optional provider plugin modules (comma-separated).
# Each module should call register_provider(...) from llm.factory during import.
# Example: LLM_PROVIDER_PLUGIN_MODULES=custom_llm_plugins.my_provider
LLM_PROVIDER_PLUGIN_MODULES=

# Validate model names against provider catalogs before saving workspace config.
LLM_MODEL_VALIDATION_REQUIRED=True
LLM_PROVIDER_CATALOG_TIMEOUT_SECONDS=12
LLM_PROVIDER_CATALOG_CACHE_TTL_SECONDS=300

# Encryption key for stored workspace LLM API keys.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# LLM_CONFIG_ENCRYPTION_KEY=

# Supabase (optional)
# IMPORTANT: never commit real keys. Keep them only in local/secret env files.
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_ANON_KEY=your_supabase_anon_key_here
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# Optional direct DB URL for applying schema migrations via script
# SUPABASE_DB_URL=postgresql://postgres:<db_password>@db.<project-ref>.supabase.co:5432/postgres
# Optional component-based direct DB config (script can compose URL if SUPABASE_DB_URL is empty)
# SUPABASE_DB_HOST=db.<project-ref>.supabase.co
# SUPABASE_DB_PORT=5432
# SUPABASE_DB_NAME=postgres
# SUPABASE_DB_USER=postgres
# SUPABASE_DB_PASSWORD=<db_password>
# Project-specific example (replace <db_password> with your real Supabase DB password)
# SUPABASE_DB_URL=postgresql://postgres:<db_password>@db.bmiegetlwjlfrgrljhbg.supabase.co:5432/postgres
# SUPABASE_DB_HOST=db.bmiegetlwjlfrgrljhbg.supabase.co

# MCP External Tool Routing (optional)
# Enable MCP-first execution for outbound HTTP calls used by agentic workflows.
MCP_ENABLED=False
# MCP_SERVER_URL=http://127.0.0.1:8787
# MCP_API_KEY=
MCP_TIMEOUT_SECONDS=15
MCP_FAIL_OPEN=True
# Require MCP-only execution for agent outbound HTTP calls (no direct fallback)
MCP_AGENT_STRICT_MODE=False
# MCP_HTTP_GET_TOOL=http.get
# MCP_HTTP_POST_TOOL=http.post

# Database (MySQL)
# Update 'password' with your actual MySQL root password
DATABASE_URL=mysql+asyncmy://root:password@localhost:3306/sweden_relocators_ai
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Checkpointing (SQLite for LangGraph state persistence)
CHECKPOINT_DB=sqlite:///checkpoints.db

# Vector Store (from n8n workflow)
# n8n used: VECTOR_DB_URL=http://localhost:8000/api/v1/query
# top_k=3 for retrieval
# VECTOR_STORE_TYPE=chroma
# VECTOR_STORE_PATH=./data/chroma_db
# VECTOR_DB_URL=http://localhost:8000
# VECTOR_TOP_K=3

# Pinecone (if using)
# PINECONE_API_KEY=your_pinecone_key
# PINECONE_ENVIRONMENT=us-east-1
# PINECONE_INDEX=sweden-relocators

# Email Configuration (for admin notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@swedenrelocators.com

# Admin Emails
ADMIN_EMAILS=["admin@swedenrelocators.se"]

# Security
API_KEYS=[]  # Add your API keys here as comma-separated list
RATE_LIMIT_PER_MINUTE=100

# Workflow Configuration
MAX_CONVERSATION_HISTORY=10
SPAM_THRESHOLD=1.0
INTENT_CONFIDENCE_THRESHOLD=0.8

# Knowledge Base (from n8n workflow: top_k=3)
KNOWLEDGE_BASE_TOP_K=5
KNOWLEDGE_BASE_SIMILARITY_THRESHOLD=0.7

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/agent.log

# Performance
WORKERS=4
REQUEST_TIMEOUT=30

# URLs
WEBSITE_URL=https://swedenrelocators.se
